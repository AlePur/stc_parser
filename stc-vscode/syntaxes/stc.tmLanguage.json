{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "STC",
  "scopeName": "source.stc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#service-decl" },
    { "include": "#external-decl" },
    { "include": "#routine-decl" },
    { "include": "#state-decl" },
    { "include": "#transition" },
    { "include": "#body-keywords" },
    { "include": "#external-types" },
    { "include": "#stct-test-decl" },
    { "include": "#stct-example-decl" },
    { "include": "#stct-assignment" },
    { "include": "#stct-keywords" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.stc",
          "match": "//.*$"
        },
        {
          "name": "comment.line.hash.stc",
          "match": "#.*$"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.stc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.stc",
          "match": "\\\\."
        }
      ]
    },

    "numbers": {
      "name": "constant.numeric.stc",
      "match": "\\b[0-9]+\\b"
    },

    "service-decl": {
      "comment": "service CheckoutService  |  service CheckoutService from \"./checkout\"",
      "match": "\\b(service)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(from)\\s*(\"[^\"]*\"))?",
      "captures": {
        "1": { "name": "keyword.control.stc" },
        "2": { "name": "entity.name.type.service.stc" },
        "3": { "name": "keyword.control.import.stc" },
        "4": { "name": "string.quoted.double.stc" }
      }
    },

    "external-decl": {
      "comment": "external DB MainDB",
      "match": "\\b(external)\\s+(DB|API|DATA)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.stc" },
        "2": { "name": "support.type.external.stc" },
        "3": { "name": "entity.name.type.external.stc" }
      }
    },

    "routine-decl": {
      "comment": "routine [unfailing] Name(Dep, ...) { ... }",
      "begin": "\\b(routine)(?:\\s+(unfailing))?\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.control.stc" },
        "2": { "name": "storage.modifier.stc" },
        "3": { "name": "entity.name.function.routine.stc" },
        "4": { "name": "punctuation.definition.parameters.begin.stc" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.parameters.end.stc" }
      },
      "patterns": [
        { "include": "#dep-list" }
      ]
    },

    "state-decl": {
      "comment": "[first|terminal] state StateName",
      "match": "\\b(first|terminal)(?=\\s+state\\b)|\\b(state)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.modifier.stc" },
        "2": { "name": "keyword.control.stc" },
        "3": { "name": "entity.name.type.state.stc" }
      }
    },

    "transition": {
      "comment": "on success -> Processing",
      "match": "\\b(on)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(->)\\s*([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.flow.stc" },
        "2": { "name": "variable.other.event.stc" },
        "3": { "name": "keyword.operator.arrow.stc" },
        "4": { "name": "entity.name.type.state.stc" }
      }
    },

    "body-keywords": {
      "comment": "Keywords used inside routine and state bodies",
      "patterns": [
        {
          "comment": "do/rollback",
          "match": "\\b(do|rollback)\\b",
          "name": "keyword.other.action.stc"
        },
        {
          "comment": "'to' target in do/rollback statements",
          "match": "(?<=\\\"[^\\\"]*)\\s+(to)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.stc" },
            "2": { "name": "entity.name.type.external.stc" }
          }
        },
        {
          "comment": "lock Dependency",
          "match": "\\b(lock)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.lock.stc" },
            "2": { "name": "entity.name.type.external.stc" }
          }
        },
        {
          "comment": "unlock Dependency",
          "match": "\\b(unlock)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.lock.stc" },
            "2": { "name": "entity.name.type.external.stc" }
          }
        },
        {
          "comment": "has [...] inside first state",
          "match": "\\b(has)\\b",
          "name": "keyword.other.stc"
        },
        {
          "comment": "steps [...] inside state",
          "match": "\\b(steps)\\b",
          "name": "keyword.other.stc"
        }
      ]
    },

    "external-types": {
      "comment": "DB / API / DATA when used standalone (e.g. inside dep lists)",
      "match": "\\b(DB|API|DATA)\\b",
      "name": "support.type.external.stc"
    },

    "dep-list": {
      "comment": "Identifiers inside routine dependency parentheses",
      "match": "[A-Za-z_][A-Za-z0-9_]*",
      "name": "variable.parameter.stc"
    },

    "stct-test-decl": {
      "comment": "test IdempotencyTest { ... }",
      "match": "\\b(test)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.stc" },
        "2": { "name": "entity.name.type.test.stc" }
      }
    },

    "stct-example-decl": {
      "comment": "example DATA ExampleUser",
      "match": "\\b(example)\\s+(DB|API|DATA)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.stc" },
        "2": { "name": "support.type.external.stc" },
        "3": { "name": "entity.name.type.external.stc" }
      }
    },

    "stct-assignment": {
      "comment": "service1 := start CheckoutService(...)",
      "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(:=)\\s*(start)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "variable.other.stc" },
        "2": { "name": "keyword.operator.assignment.stc" },
        "3": { "name": "keyword.control.stc" },
        "4": { "name": "entity.name.type.service.stc" }
      }
    },

    "stct-keywords": {
      "comment": "Keywords specific to .stct test files",
      "patterns": [
        {
          "comment": "run ... to Target[^]",
          "match": "\\b(run)\\b",
          "name": "keyword.control.stc"
        },
        {
          "comment": "assert statement: assert Var writes = N",
          "match": "\\b(assert)\\b",
          "name": "keyword.control.stc"
        },
        {
          "comment": "'to' keyword in run statements",
          "match": "\\b(to)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.stc" },
            "2": { "name": "entity.name.type.state.stc" }
          }
        },
        {
          "comment": "^ state-entry marker (e.g. Processing^)",
          "match": "\\^",
          "name": "keyword.operator.stc"
        },
        {
          "comment": "'writes' assertion qualifier",
          "match": "\\b(writes)\\b",
          "name": "keyword.other.stc"
        },
        {
          "comment": "= operator in assertions",
          "match": "(?<=\\bwrites\\b\\s*)=",
          "name": "keyword.operator.stc"
        },
        {
          "comment": "strict qualifier comment keyword — already caught by comment rule, listed here for clarity",
          "match": "\\b(strict)\\b",
          "name": "keyword.other.stc"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.stc",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.stc",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.list.begin.stc",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.list.end.stc",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.stc",
          "match": ","
        },
        {
          "name": "punctuation.separator.key-value.stc",
          "match": ":"
        }
      ]
    }
  }
}
